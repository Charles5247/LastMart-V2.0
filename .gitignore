.env
.env.local
.env.production
.env.production.local
.env.staging
backend/.env
backend/.env.production

# Database files
*.db
*.db-shm
*.db-wal

# Uploaded files (local dev)
public/uploads/
backend/uploads/

# PM2
.pm2/
logs/
*.log

# Misc
.DS_Store
Thumbs.db
*.tsbuildinfo
.wrangler/

# Docker
.dockerignore
