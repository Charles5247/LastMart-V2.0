# ─── .env.example ─────────────────────────────────────────────────────────────
# Copy this file and fill in your values:
#   cp .env.example .env                    (Docker / VPS)
#   cp .env.example .env.local              (local development)
#
# NEVER commit .env or .env.local to git. 

# ── Frontend (Next.js) ─────────────────────────────────────────────────────────
# URL of the Express backend — used by next.config.js to proxy /api/* requests
BACKEND_API_URL=http://localhost:5000

# Public site URL — used for SEO metadataBase, sitemap, and robots.txt canonical URLs
NEXT_PUBLIC_SITE_URL=https://lastmart.onrender.com

# Google Search Console verification code (optional)
GOOGLE_SITE_VERIFICATION=your_google_site_verification_code

# Paystack public key (safe to expose — used in browser for payment widget)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Multi-Frontend URLs (used for cross-platform CTAs) ─────────────────────────
NEXT_PUBLIC_VENDOR_URL=https://lastmart-vendor.onrender.com
NEXT_PUBLIC_RIDER_URL=https://lastmart-rider.onrender.com
NEXT_PUBLIC_ADMIN_URL=https://lastmart-admin.onrender.com

# ── Backend (Express) ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# URLs of all frontends — comma-separated list used for CORS allow-list
# In production set this to all 4 frontend origins:
# FRONTEND_URL=https://lastmart.onrender.com,https://lastmart-vendor.onrender.com,https://lastmart-rider.onrender.com,https://lastmart-admin.onrender.com
FRONTEND_URL=http://localhost:3006,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Secret for signing JWTs — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# SQLite database path (relative to backend directory, or absolute)
DATABASE_PATH=../lastmart.db

# ── Payments ───────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_WEBHOOK_HASH=your_flutterwave_webhook_hash

# ── Email ──────────────────────────────────────────────────────────────────────
# Option A — SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B — SMTP (e.g. Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=LastMart
EMAIL_FROM_ADDRESS=noreply@lastmart.com
