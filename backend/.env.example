# ─── LastMart Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default - no config needed, file created automatically)
DATABASE_PATH=../lastmart.db

# PostgreSQL (Supabase / Neon / Railway / PlanetScale)
# DATABASE_URL=postgresql://user:password@host:5432/lastmart

# MongoDB
# MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/lastmart

# ── Payment Gateways ──────────────────────────────────────────────────────────
# Paystack - https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Flutterwave - https://developer.flutterwave.com/docs/
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_your_key_here
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST_your_key_here
FLW_WEBHOOK_HASH=your_flutterwave_webhook_secret_hash

# ── Email ─────────────────────────────────────────────────────────────────────
# Option 1: SendGrid (recommended for production)
# SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Option 2: SMTP (Gmail, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password

EMAIL_FROM_NAME=LastMart
EMAIL_FROM_ADDRESS=noreply@lastmart.com

# ── File Storage ──────────────────────────────────────────────────────────────
# Option 1: Cloudinary (recommended)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Option 2: AWS S3
# AWS_S3_BUCKET=lastmart-uploads
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXX
# AWS_SECRET_ACCESS_KEY=your_secret_access_key

# ── AI / LAMA ─────────────────────────────────────────────────────────────────
# Optional: Plug in OpenAI for enhanced LAMA responses
# OPENAI_API_KEY=sk-your_openai_api_key

# ── Webhooks ──────────────────────────────────────────────────────────────────
# Set this in your payment gateway dashboards
# Paystack webhook:    https://your-backend.com/api/payment/webhook/paystack
# Flutterwave webhook: https://your-backend.com/api/payment/webhook/flutterwave
