# ─── LastMart Frontend Environment Variables ──────────────────────────────────
# Copy this to .env.local (never commit .env.local to git)

# Backend API URL - change to your deployed backend URL in production
BACKEND_API_URL=https://lastmart-v2-0.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# Paystack public key (safe to expose in frontend - public key only)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
