{
  "expo": {
    "name": "LastMart",
    "slug": "lastmart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lastmart.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "LastMart uses your location to find nearby vendors.",
        "NSCameraUsageDescription": "LastMart needs camera access for KYC document photos.",
        "NSPhotoLibraryUsageDescription": "LastMart needs photo library access for product images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.lastmart.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        { "photosPermission": "LastMart needs photos access to upload product images and KYC documents." }
      ],
      [
        "expo-location",
        { "locationWhenInUsePermission": "LastMart uses your location to find vendors near you." }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#16a34a",
          "sounds": ["./assets/notification.wav"]
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://your-backend.railway.app",
      "eas": { "projectId": "your-eas-project-id" }
    },
    "scheme": "lastmart"
  }
}
